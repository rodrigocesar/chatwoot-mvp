# Moonu Simulator — copy to .env.local and adjust

# PostgreSQL (docker compose moonu-db on port 5433)
DATABASE_URL=postgresql://moonu:moonu@localhost:5433/moonu_simulator

# Chatwoot adapter mode: mock (default) | real
CHATWOOT_MODE=mock

# Required when CHATWOOT_MODE=real (Slice 2+)
CHATWOOT_BASE_URL=http://localhost:3001

# Slice 3 Platform API automation (optional)
# CHATWOOT_PLATFORM_API_TOKEN=

# Optional admin token for API routes
# ADMIN_TOKEN=
